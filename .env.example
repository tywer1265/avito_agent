# ═══════════════════════════════════════════════════════════════
# Avito Agents — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git. Add .env to .gitignore immediately.
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_ENV=development                      # development | production
APP_NAME=avito_agents
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
TZ=Europe/Moscow                         # All schedules run in MSK

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
# Full DSN (auto-built from above in config.py, listed here for reference)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crm_db

# ── Anthropic Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Model aliases — change here to upgrade globally
CLAUDE_SONNET_MODEL=claude-sonnet-4-5   # complex: generation, analysis
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001     # simple: classification, routing
# Hard cost caps
ANTHROPIC_MONTHLY_BUDGET_USD=280.00     # alert fires at $250, hard stop at $280
ANTHROPIC_MAX_TOKENS_SONNET=2048
ANTHROPIC_MAX_TOKENS_HAIKU=512

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_OWNER_CHAT_ID=your_personal_chat_id   # receives all alerts + reports
TELEGRAM_ALERT_CHAT_ID=your_personal_chat_id   # can be same or a separate alerts channel

# ── Avito API ─────────────────────────────────────────────────
# Obtain from https://developers.avito.ru/
AVITO_CLIENT_ID=your_avito_client_id
AVITO_CLIENT_SECRET=your_avito_client_secret
AVITO_USER_ID=your_avito_user_id
AVITO_API_BASE_URL=https://api.avito.ru

# ── Nano Banana (image generation) ───────────────────────────
NANO_BANANA_API_KEY=your_nano_banana_key
NANO_BANANA_API_URL=https://api.nanobanana.io/v1   # update if endpoint changes
NANO_BANANA_MAX_RETRIES=2               # max regeneration attempts per image

# ── NewsAPI ───────────────────────────────────────────────────
# Obtain from https://newsapi.org/
NEWS_API_KEY=your_newsapi_key
NEWS_API_BASE_URL=https://newsapi.org/v2

# ── VKontakte ─────────────────────────────────────────────────
# Service token from https://vk.com/dev
VK_SERVICE_TOKEN=your_vk_service_token
VK_API_VERSION=5.199

# ── Wildberries (public API, no auth required for search) ─────
WB_API_BASE_URL=https://search.wb.ru

# ── FastAPI server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false                         # true only in development

# ── Scheduler ─────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/Moscow
# Peak traffic hours for Avito posting (comma-separated, 24h format)
AVITO_PEAK_HOURS=9,12,18,20

# ── Business rules ────────────────────────────────────────────
MIN_MARGIN_PERCENT=40                    # Procurement: never buy below this margin
EXPENSE_ALERT_THRESHOLD=0.60            # Accountant: alert if expenses > 60% revenue
CONVERSION_DROP_ALERT=0.30              # Analyst: alert if conversion drops > 30%
CLIENT_RESPONSE_SLA_MINUTES=5           # Client Manager: target response time
TREND_MIN_SOURCES=2                     # Trend Hunter: valid if found in N+ sources
TREND_SCORE_THRESHOLD=30                # Minimum score (out of 50) to act on trend
INVENTORY_REORDER_DAYS=14               # Procurement: reorder when stock < 14 days supply

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=generate_a_random_64char_hex_string_here   # used for internal API auth
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
